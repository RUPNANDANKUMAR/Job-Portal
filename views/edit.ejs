<!DOCTYPE html>
<html>
<head>
    <title>Edit Job</title>
</head>
<body>

<h2>Edit Job</h2>

<form action="/jobs/<%= job._id %>?_method=PUT" method="POST">

<label>Job Title</label><br>
<input type="text" name="title" value="<%= job.title %>" required>
<br><br>

<label>Company</label><br>
<input type="text" name="company" value="<%= job.company %>" required>
<br><br>

<label>Location</label><br>
<input type="text" name="location" value="<%= job.location %>">
<br><br>

<label>Salary</label><br>
<input type="number" name="salary" value="<%= job.salary %>">
<br><br>

<label>Description</label><br>
<textarea name="description" required><%= job.description %></textarea>
<br><br>

<button type="submit">Update Job</button>

</form>

<br>

<a href="/jobs">Back to Jobs</a>

</body>
</html>