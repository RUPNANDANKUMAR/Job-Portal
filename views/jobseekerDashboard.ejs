<!DOCTYPE html>
<html>
<head>

<title>Jobseeker Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

    <div class="container mt-5">
        <h2>Available Jobs</h2>
        <div class="row">
        <% jobs.forEach(job=>{ %>
        <div class="col-md-4">
        <div class="card mb-3">
        <div class="card-body">
        <h5><%= job.title %></h5>
        <p><%= job.company %></p>
        <p><%= job.location %></p>
        <a href="/jobs/<%= job._id %>" class="btn btn-primary">View Job</a>
        </div>
        </div>
        </div>
        <% }) %>
        </div>
    </div>

</body>
</html>