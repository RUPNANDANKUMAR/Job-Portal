<!DOCTYPE html>
<html>
<head>

<title>Recruiter Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

<div class="container mt-5">

<h2>Recruiter Dashboard</h2>

<a href="/jobs/new" class="btn btn-success mb-3">Post New Job</a>

<table class="table table-bordered">

<tr>
<th>Title</th>
<th>Company</th>
<th>Location</th>
<th>Actions</th>
</tr>

<% jobs.forEach(job=>{ %>

<tr>

<td><%= job.title %></td>
<td><%= job.company %></td>
<td><%= job.location %></td>

<td>

<a href="/jobs/<%= job._id %>" class="btn btn-primary btn-sm">View</a>

<a href="/jobs/<%= job._id %>/edit" class="btn btn-warning btn-sm">Edit</a>

<form action="/jobs/<%= job._id %>?_method=DELETE" method="POST" style="display:inline;">
<button class="btn btn-danger btn-sm">Delete</button>
</form>

</td>

</tr>

<% }) %>

</table>

</div>

</body>
</html>